# Ignore WordPress core
/wp-admin/
/wp-includes/

# Ignore most of wp-content
/wp-content/*
!/wp-content/themes/
/wp-content/themes/*
!/wp-content/themes/bricks-child/

!/wp-content/plugins/

/wp-content/plugins/*
!/wp-content/plugins/bewdley-custom/
!/wp-content/plugins/bewdley-custom/**

# Ignore uploads and cache
/wp-content/uploads/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backups*/
/wp-content/updraft/
/wp-content/ai1wm-backups/

# Ignore Local Connect/Flywheel transfer artifacts
/.connect-manifest.json
/.connect-push.sql

# Ignore local environment files
wp-config.php
.env
.env.*

# Ignore logs
*.log
debug.log

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore editor configs
.vscode/
.idea/

# Ignore node/build
node_modules/
dist/
build/