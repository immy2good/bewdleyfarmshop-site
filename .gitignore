# Ignore WordPress core
/wp-admin/
/wp-includes/

# Ignore most of wp-content
/wp-content/*
!/wp-content/themes/
/wp-content/themes/*
!/wp-content/themes/bricks-child/

/wp-content/plugins/*
!/wp-content/plugins/bewdley-custom/

# Ignore uploads and cache
/wp-content/uploads/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backups*/
/wp-content/updraft/

# Ignore local environment files
wp-config.php
.env
.env.*

# Ignore logs
*.log
debug.log

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore editor configs
.vscode/
.idea/

# Ignore node/build
node_modules/
dist/
build/